{
  "manifest_version": 3,
  "name": "canBet",
  "version": "1.3",
  "description": "Canvas gamification extension",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.instructure.com/*",
    "https://canbet.live/*",
    "https://www.canbet.live/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*",
        "https://canbet.live/*",
        "https://www.canbet.live/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/canbet.png"
  }
}