{
  "manifest_version": 3,
  "name": "canBet",
  "version": "2.2",
  "description": "Canvas gamification extension",
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "*://*.instructure.com/*",
    "*://*.edu/*",
    "https://canbet.live/*",
    "https://www.canbet.live/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "canBet",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/canbet.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*",
        "*://*.edu/*",
        "https://canbet.live/*",
        "https://www.canbet.live/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/canbet.png"
  }
}
