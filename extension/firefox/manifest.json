{
  "manifest_version": 3,
  "name": "canBet",
  "version": "2.1",
  "description": "Canvas gamification extension",
  "permissions": [
    "storage",
    "notifications",
    "*://*.instructure.com/*",
    "*://canvas.*.edu/*",
    "https://canbet.live/*",
    "https://www.canbet.live/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*",
        "*://canvas.*.edu/*",
        "https://canbet.live/*",
        "https://www.canbet.live/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "canbet@extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}